<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background">

    <!-- ================= CONTENIDO PRINCIPAL ================= -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp"
            android:background="@color/background">

            <!-- Toolbar -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@color/background"
                app:title="Agente Gamer"
                app:elevation="0dp"
                app:titleTextColor="@color/text_primary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- ================= BENTO GRID ================= -->

            <!-- CARD TOTAL - Grande -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/surface_variant"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/toolbar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total gastado"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/manrope_medium"/>

                    <TextView
                        android:id="@+id/tvTotalGastos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0,00 €"
                        android:textColor="@color/text_primary"
                        android:textSize="36sp"
                        android:fontFamily="@font/manrope_bold"
                        android:layout_marginTop="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical">

                        <View
                            android:id="@+id/viewIndicador"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/indicador_circle"/>

                        <TextView
                            android:id="@+id/tvRecomendacion"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Estado financiero"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:fontFamily="@font/manrope_regular"/>

                        <!-- Indicador de Tendencia (NUEVO) -->
                        <TextView
                            android:id="@+id/tvIndicadorTendencia"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→ 0%"
                            android:textColor="@color/estado_neutro"
                            android:textSize="12sp"
                            android:fontFamily="@font/manrope_bold"
                            android:background="@drawable/bg_tendencia_indicator"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:visibility="gone"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ROW 2: Stats Cards -->
            <LinearLayout
                android:id="@+id/rowStats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:weightSum="2"
                app:layout_constraintTop_toBottomOf="@id/cardTotal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- CARD PRESUPUESTO -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPresupuesto"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/surface_variant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Presupuesto"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="@font/manrope_medium"/>

                        <TextView
                            android:id="@+id/tvPresupuesto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0,00 €"
                            android:textColor="@color/accent_green"
                            android:textSize="20sp"
                            android:fontFamily="@font/manrope_bold"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="mensual"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"
                            android:fontFamily="@font/manrope_regular"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CARD RESTANTE -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRestante"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/surface_variant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Restante"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="@font/manrope_medium"/>

                        <TextView
                            android:id="@+id/tvRestante"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0,00 €"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:fontFamily="@font/manrope_bold"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="disponible"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"
                            android:fontFamily="@font/manrope_regular"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ================= CARDS NUEVOS PARA DASHBOARD ================= -->

            <!-- CARD TENDENCIA (NUEVO) - Gráfico de línea de gastos históricos -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTendencia"
                android:layout_width="0dp"
                android:layout_height="200dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/surface_variant"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/rowStats"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tendencia de gastos"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/manrope_medium"/>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChartTendencia"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD RECOMENDACIONES (NUEVO) - Tips del Agente Financiero -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRecomendaciones"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/surface_variant"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/cardTendencia"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_agent"
                            android:padding="4dp"
                            app:tint="@color/accent_green"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tu Agente dice:"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:fontFamily="@font/manrope_medium"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRecomendacionAgente"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Configura tu presupuesto para ver recomendaciones."
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/manrope_regular"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD ÚLTIMOS GASTOS (NUEVO) - Lista horizontal reciente -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUltimosGastos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/surface_variant"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/cardRecomendaciones"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Últimos gastos"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/manrope_medium"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerUltimosGastos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        app:reverseLayout="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD GRAFICO (EXISTENTE) - PieChart de categorías -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGrafico"
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/surface_variant"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/cardUltimosGastos"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gastos por categoría"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/manrope_medium"/>

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pieChart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ================= BOTTOM NAVIGATION ================= -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ================= MENÚ LATERAL ================= -->

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/surface"
        app:menu="@menu/drawer_menu"
        app:headerLayout="@layout/drawer_header"
        app:itemTextColor="@color/text_primary"
        app:itemIconTint="@color/text_secondary"
        app:itemRippleColor="@color/surface_variant"/>

</androidx.drawerlayout.widget.DrawerLayout>