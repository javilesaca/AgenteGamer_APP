@startuml
left to right direction
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 60
skinparam defaultFontSize 9
skinparam defaultFontName "DejaVu Sans"
skinparam maxMessageSize 500

package "ui.activities" {
  class BaseNavActivity #lightblue {
    - int mSelectedItemId
    + setupBottomNavigation(int)
    + onResume()
    - navigateToActivity(int)
  }

  class MainActivity {
    - TextView tvRecomendacion, tvTotalGastos
    - TextView tvPresupuesto, tvRestante
    - PieChart pieChart
    - LineChart lineChartTendencia
    - GastoViewModel gastoViewModel
    - SistemaFinanciero sistemaFinanciero
    - String moneda
    + onCreate()
    - configurarObservers()
    - observarMoneda()
  }

  class ListaGastosActivity {
    - RecyclerView rvGastos
    - GastoAdapter adapter
    - GastoViewModel viewModel
    + onCreate()
    - observarGastos()
  }

  class ListaJuegosActivity {
    - RecyclerView rvJuegos
    - JuegosAdapter adapter
    - GamesViewModel viewModel
    - WishlistViewModel wishlistViewModel
    + onCreate()
    - configurarBusqueda()
    - configurarPaginacion()
  }

  class ListaWishlistActivity {
    - RecyclerView rvWishlist
    - WishlistAdapter adapter
    - WishlistViewModel viewModel
    + onCreate()
    - observarWishlist()
  }

  class LanzamientosActivity {
    - RecyclerView rvLanzamientos
    - LanzamientosAdapter adapter
    - LanzamientosViewModel viewModel
    + onCreate()
    - precargarDatos()
  }

  class SplashActivity {
    - AgenteGamerApplication app
    + onCreate()
    - preloadAndNavigate()
  }

  class LoginActivity {
    - EditText etEmail, etPassword
    - FirebaseAuth mAuth
    + onCreate()
    - login()
  }

  class RegisterActivity {
    - EditText etEmail, etPassword, etNombre
    - FirebaseAuth mAuth
    - FirebaseFirestore db
    + onCreate()
    - register()
  }

  class PerfilActivity {
    - TextView tvEmail, tvNombre, tvPresupuesto
    - UserRepository userRepository
    + onCreate()
    - cargarPerfil()
  }

  class AjustesActivity {
    - EditText etPresupuesto
    - Spinner spMoneda
    - UpdateSettingsUseCase useCase
    + onCreate()
    - guardarPresupuesto()
    - guardarMoneda()
  }
}

package "ui.viewmodel" {
  class GastoViewModel {
    - GastoRepository repository
    - LiveData<List<GastoEntity>> listaGastos
    - MutableLiveData<EstadoFinancieroUI> estadoUI
    - SistemaFinanciero sistemaFinanciero
    + setSistemaFinanciero(SistemaFinanciero)
    + insertar(GastoEntity)
    + getRecomendacionDashboard(): String
  }

  class WishlistViewModel {
    - WishlistRepository repo
    - MediatorLiveData<List<WishlistItemUI>> wishlistEvaluada
    + insertar(WishlistEntity)
    + comprarJuego(WishlistEntity, double)
    + calcularTotal(): double
  }

  class GamesViewModel {
    - GamesRepository repository
    - MutableLiveData<List<GameDto>> juegos
    + cargarJuegosIniciales()
    + buscarJuegosPaginados(String, boolean)
    + obtenerFamiliasPlataformas(GameDto): Set<String>
  }

  class LanzamientosViewModel {
    - LanzamientoRepository repo
    - GamesApiService api
    + getLanzamientos(): LiveData
    + precargaProximos15Dias()
  }
}

package "domain.model" {
  class SistemaFinanciero {
    - double presupuestoMensual
    + obtenerEstado(double): EstadoFinanciero
    + evaluarCompra(double, double): String
    + estimarPrecio(GameInfo): double
    + generarRecomendacion(List<Gasto>): String
  }

  class Gasto {
    - String nombre
    - double precio
    - long fecha
  }

  class GameInfo {
    - String nombre
    - double rating
  }

  class MonthlyExpense {
    - String mes
    - double total
  }
}

package "domain.repository" {
  interface GastoRepository #lightyellow {
    + obtenerGastos(): LiveData
    + insertarGasto(GastoEntity)
    + getGastoMesActual(): LiveData
  }

  interface WishlistRepository #lightyellow {
    + obtenerTodos(String): LiveData
    + insertar(WishlistEntity)
    + getWishlistSync(): List<WishlistEntity>
  }

  interface LanzamientoRepository #lightyellow {
    + getProximosLanzamientos(long): LiveData
    + insertar(LanzamientoEntity)
  }

  interface UserRepository #lightyellow {
    + obtenerPresupuesto(OnPresupuestoCallback)
    + obtenerMoneda(OnMonedaCallback)
    + actualizarPresupuesto(double)
    + actualizarMoneda(String)
  }
}

package "data.repository" {
  class GastoRepositoryImpl {
    - GastoDao dao
    - ExecutorService executor
    - String userId
    + obtenerGastos(): LiveData
    + insertarGasto(GastoEntity)
  }

  class WishlistRepositoryImpl {
    - WishlistDao dao
    - ExecutorService executor
    - String userId
    + obtenerTodos(String): LiveData
    + insertar(WishlistEntity)
  }

  class LanzamientoRepositoryImpl {
    - LanzamientoDao dao
    - ExecutorService executor
    - String userId
    + getProximosLanzamientos(long): LiveData
    + insertar(LanzamientoEntity)
  }

  class UserRepositoryImpl {
    - FirebaseFirestore firestore
    - FirebaseAuth auth
    + obtenerPresupuesto(OnPresupuestoCallback)
    + actualizarPresupuesto(double)
  }
}

package "data.local" {
  interface GastoDao #lightyellow {
    + insertGasto(GastoEntity)
    + getAllGastos(String): LiveData
    + getGastoTotalMes(String, int, int): LiveData
    + getMonthlyTotals(String, long, int): List<MonthlyTotal>
  }

  interface WishlistDao #lightyellow {
    + insert(WishlistEntity)
    + getWishlist(String): LiveData
    + getTotalGastado(String): Double
  }

  interface LanzamientoDao #lightyellow {
    + insertar(LanzamientoEntity)
    + getProximosLanzamientos(String, long): LiveData
  }

  class GastoEntity {
    @PrimaryKey int id
    @ColumnInfo String userId
    @ColumnInfo String nombreJuego
    @ColumnInfo double precio
    @ColumnInfo long fecha
    @ColumnInfo int mes
    @ColumnInfo int anio
  }

  class WishlistEntity {
    @PrimaryKey int id
    @ColumnInfo String userId
    @ColumnInfo int gameId
    @ColumnInfo String nombre
    @ColumnInfo String fechaLanzamiento
    @ColumnInfo String plataforma
    @ColumnInfo double precioEstimado
  }

  class LanzamientoEntity {
    @PrimaryKey int id
    @ColumnInfo String userId
    @ColumnInfo int gameId
    @ColumnInfo String nombre
    @ColumnInfo long fechaLanzamiento
    @ColumnInfo String plataformas
    @ColumnInfo double rating
  }
}

package "data.remote" {
  interface GamesApiService #lightyellow {
    @GET("games") getGames(...): Call<GamesResponse>
    @GET("games") buscarJuegos(...): Call<GamesResponse>
    @GET("games") getRecentlyReleased(...): Call<GamesResponse>
  }

  class RetrofitClient {
    - static Retrofit instance
    + getInstance(): Retrofit
  }

  class GameDto {
    - int id
    - String name
    - double rating
    - String released
    - String backgroundImage
    - List<PlatformWrapper> platforms
    - double precioEstimado
  }

  class GamesResponse {
    - int count
    - List<GameDto> results
  }
}

package "di" {
  class DatabaseModule {
    {static} + provideDatabase(Context): AppDatabase
    {static} + provideGastoDao(AppDatabase): GastoDao
    {static} + provideWishlistDao(AppDatabase): WishlistDao
    {static} + provideExecutorService(): ExecutorService
  }

  class NetworkModule {
    {static} + provideRetrofit(): Retrofit
    {static} + provideGamesApiService(Retrofit): GamesApiService
  }

  class FirebaseModule {
    {static} + provideFirebaseAuth(): FirebaseAuth
    {static} + provideFirebaseFirestore(): FirebaseFirestore
  }

  class RepositoryModule {
    {abstract} + bindGastoRepository(GastoRepositoryImpl): GastoRepository
    {abstract} + bindWishlistRepository(WishlistRepositoryImpl): WishlistRepository
    {abstract} + bindUserRepository(UserRepositoryImpl): UserRepository
  }
}

package "util" {
  class MoneyUtils {
    {static} + format(double, String): String
    {static} + convertirDesdeEUR(double, String): double
  }

  class FechaUtils {
    {static} + hoy(): String
    {static} + diasHasta(long): long
    {static} + parseFecha(String): Date
  }

  class PlatformUtils {
    {static} + getPlatformFamilies(GameDto): Set<String>
    {static} + getFamilyIcon(String): int
  }

  class NotificationHelper {
    {static} + mostrar(Context, String, String)
  }
}

package "worker" {
  class SistemaFinancieroWorker {
    - WishlistRepository wishlistRepo
    - GastoRepository gastoRepo
    - ValidatePurchaseUseCase validatePurchaseUseCase
    + doWork(): Result
  }

  class LanzamientoWorker {
    - WishlistRepository repo
    + doWork(): Result
  }
}

' === RELACIONES ===
BaseNavActivity <|-- MainActivity
BaseNavActivity <|-- ListaGastosActivity
BaseNavActivity <|-- ListaJuegosActivity
BaseNavActivity <|-- ListaWishlistActivity
BaseNavActivity <|-- LanzamientosActivity

MainActivity --> GastoViewModel
ListaGastosActivity --> GastoViewModel
ListaJuegosActivity --> GamesViewModel
ListaWishlistActivity --> WishlistViewModel
LanzamientosActivity --> LanzamientosViewModel

GastoViewModel ..> GastoRepository
WishlistViewModel ..> WishlistRepository
WishlistViewModel ..> LanzamientoRepository
WishlistViewModel ..> GastoRepository
WishlistViewModel ..> UserRepository
GamesViewModel ..> GamesRepository
LanzamientosViewModel ..> LanzamientoRepository
LanzamientosViewModel ..> GamesApiService

GastoRepository <|.. GastoRepositoryImpl
WishlistRepository <|.. WishlistRepositoryImpl
LanzamientoRepository <|.. LanzamientoRepositoryImpl
UserRepository <|.. UserRepositoryImpl

GastoRepositoryImpl --> GastoDao
WishlistRepositoryImpl --> WishlistDao
LanzamientoRepositoryImpl --> LanzamientoDao

GastoDao --> GastoEntity
WishlistDao --> WishlistEntity
LanzamientoDao --> LanzamientoEntity

GamesApiService ..> GameDto
GamesApiService ..> GamesResponse
RetrofitClient ..> GamesApiService

GastoViewModel --> SistemaFinanciero
GamesViewModel --> SistemaFinanciero

DatabaseModule ..> GastoDao
DatabaseModule ..> WishlistDao
NetworkModule ..> GamesApiService
FirebaseModule ..> FirebaseAuth
FirebaseModule ..> FirebaseFirestore
RepositoryModule ..> GastoRepositoryImpl
RepositoryModule ..> WishlistRepositoryImpl
RepositoryModule ..> UserRepositoryImpl

SistemaFinancieroWorker ..> WishlistRepository
SistemaFinancieroWorker ..> GastoRepository
SistemaFinancieroWorker ..> NotificationHelper

LanzamientoWorker ..> WishlistRepository
LanzamientoWorker ..> NotificationHelper

@enduml
